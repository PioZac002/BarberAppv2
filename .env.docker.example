# Copy this file to .env.docker and fill in the values.
# .env.docker is gitignored — never commit it.

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: local PostgreSQL container (default for Docker)
DATABASE_URL=postgresql://barberapp:barberapp_pass@db:5432/barberapp
DATABASE_SSL=false

# Option B: external database (e.g. Render) — comment out Option A and uncomment below
# DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>
# DATABASE_SSL=true

# ── Required ──────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=replace_with_a_long_random_string

# ── CORS: URL the browser uses to reach the frontend ─────────────────────────
FRONTEND_URL=http://localhost

# ── Public URL of the backend (used to build uploaded-file URLs) ──────────────
BACKEND_URL=http://localhost:3000
