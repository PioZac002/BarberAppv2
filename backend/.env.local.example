# Copy this file to .env.local to use the local Docker DB instead of Render.
# .env.local is gitignored — it never gets committed.
#
# Usage:
#   cp backend/.env.local.example backend/.env.local
#
# This file is loaded after .env and overrides only the listed variables.
# All other variables (JWT_SECRET, PORT, FRONTEND_URL, etc.) are inherited from .env.

DATABASE_URL=postgresql://barberapp:barberapp_pass@localhost:5432/barberapp
DATABASE_SSL=false
